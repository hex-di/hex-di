{
  "name": "hex-di",
  "version": "0.3.0",
  "private": true,
  "description": "HexDI - Hexagonal Dependency Injection for TypeScript",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest typecheck",
    "typecheck": "node scripts/turbo-publishable.mjs typecheck",
    "lint": "node scripts/turbo-publishable.mjs lint",
    "lint:fix": "node scripts/turbo-publishable.mjs lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r clean",
    "check:readmes": "node scripts/check-publishable-readmes.mjs",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "madge:circular": "bash scripts/check-circular.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-antfu": "^3.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^5.83.0",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.50.1",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@types/node": "25.0.3",
      "vitest": "4.0.18"
    }
  }
}
