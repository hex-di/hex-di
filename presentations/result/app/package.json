{
  "name": "@hex-di/result-presentation",
  "version": "0.0.0",
  "private": true,
  "description": "Interactive presentation introducing HexDI through the Result library",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@hex-di/core": "workspace:*",
    "@hex-di/flow": "workspace:*",
    "@hex-di/flow-react": "workspace:*",
    "@hex-di/graph": "workspace:*",
    "@hex-di/logger": "workspace:*",
    "@hex-di/query": "workspace:*",
    "@hex-di/query-react": "workspace:*",
    "@hex-di/react": "workspace:*",
    "@hex-di/result": "workspace:*",
    "@hex-di/runtime": "workspace:*",
    "@hex-di/store": "workspace:*",
    "@hex-di/store-react": "workspace:*",
    "@hex-di/tracing": "workspace:*",
    "motion": "^12.34.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shiki": "^3.7.0",
    "spectacle": "^10.2.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "jsdom": "^24.1.3",
    "typescript": "^5.6.3",
    "vite": "^7.3.0",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
