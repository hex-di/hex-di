{
  "name": "@hex-di/tracing-zipkin",
  "version": "0.3.0",
  "description": "Zipkin exporter adapter for HexDI distributed tracing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "zipkin",
    "opentelemetry",
    "tracing",
    "distributed-tracing",
    "hexagonal-architecture",
    "dependency-injection",
    "typescript",
    "type-safe"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "libs/tracing/zipkin"
  },
  "bugs": {
    "url": "https://github.com/hex-di/hex-di/issues"
  },
  "homepage": "https://github.com/hex-di/hex-di/tree/main/libs/tracing/zipkin#readme",
  "dependencies": {
    "@hex-di/tracing": "workspace:^",
    "@hex-di/tracing-otel": "workspace:^",
    "@opentelemetry/exporter-zipkin": "^2.5.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-trace-base": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "typescript": "^5.7.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
