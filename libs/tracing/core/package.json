{
  "name": "@hex-di/tracing",
  "version": "0.2.1",
  "description": "Distributed tracing support for HexDI - W3C Trace Context, OTel-compatible spans, zero dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./ports": {
      "import": {
        "types": "./dist/ports/index.d.ts",
        "default": "./dist/ports/index.js"
      },
      "require": {
        "types": "./dist/ports/index.d.cts",
        "default": "./dist/ports/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "distributed-tracing",
    "tracing",
    "opentelemetry",
    "w3c-trace-context",
    "hexagonal-architecture",
    "dependency-injection",
    "typescript",
    "type-safe"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "libs/tracing/core"
  },
  "bugs": {
    "url": "https://github.com/hex-di/hex-di/issues"
  },
  "homepage": "https://github.com/hex-di/hex-di/tree/main/libs/tracing/core#readme",
  "dependencies": {},
  "devDependencies": {
    "@hex-di/core": "workspace:*",
    "@hex-di/graph": "workspace:*",
    "@hex-di/runtime": "workspace:*",
    "@types/node": "25.0.3"
  },
  "peerDependencies": {
    "@hex-di/core": "workspace:*",
    "@hex-di/runtime": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
