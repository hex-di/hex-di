{
  "name": "@hex-di/clock",
  "version": "0.1.0",
  "description": "Injectable clock, sequence generation, and timer abstractions for HexDI — GxP-compliant timing infrastructure",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing/index.d.ts",
        "default": "./dist/testing/index.js"
      },
      "require": {
        "types": "./dist/testing/index.d.cts",
        "default": "./dist/testing/index.cjs"
      }
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit",
    "test:mutation": "stryker run"
  },
  "keywords": [
    "clock",
    "timing",
    "sequence",
    "gxp",
    "hexagonal-architecture",
    "dependency-injection",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "libs/clock/core"
  },
  "bugs": {
    "url": "https://github.com/hex-di/hex-di/issues"
  },
  "homepage": "https://github.com/hex-di/hex-di/tree/main/libs/clock/core#readme",
  "dependencies": {},
  "devDependencies": {
    "@hex-di/graph": "workspace:*",
    "@hex-di/runtime": "workspace:*",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@types/node": "25.0.3"
  },
  "peerDependencies": {
    "@hex-di/core": "workspace:*",
    "@hex-di/result": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
