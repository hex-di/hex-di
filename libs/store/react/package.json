{
  "name": "@hex-di/store-react",
  "version": "0.2.1",
  "description": "React integration for @hex-di/store - type-safe hooks for state, atoms, derived values, and async derived",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit",
    "test:mutation": "stryker run"
  },
  "keywords": [
    "store",
    "state-management",
    "react",
    "hooks",
    "hex-di",
    "typescript",
    "type-safe"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "libs/store/react"
  },
  "dependencies": {
    "@hex-di/store": "workspace:*",
    "@hex-di/react": "workspace:*",
    "@hex-di/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^24.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
