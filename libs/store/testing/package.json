{
  "name": "@hex-di/store-testing",
  "version": "0.3.0",
  "description": "Testing utilities for @hex-di/store - mock adapters, assertions, and helpers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit",
    "test:mutation": "stryker run"
  },
  "keywords": [
    "store",
    "state",
    "testing",
    "vitest",
    "mock",
    "assertions",
    "hex-di"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "libs/store/testing"
  },
  "dependencies": {
    "@hex-di/core": "workspace:*",
    "@hex-di/graph": "workspace:*",
    "@hex-di/result": "workspace:*",
    "@hex-di/runtime": "workspace:*",
    "@hex-di/store": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=4.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
