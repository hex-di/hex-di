{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "reporters": ["html", "clear-text", "progress"],
  "plugins": ["@stryker-mutator/vitest-runner"],
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "vitest": {
    "related": false
  },
  "mutate": ["src/introspection/**/*.ts", "!src/**/index.ts"],
  "ignorePatterns": ["dist", "node_modules", "docs"],
  "thresholds": {
    "high": 85,
    "low": 75,
    "break": 75
  },
  "concurrency": 4,
  "timeoutMS": 10000,
  "disableTypeChecks": "**/*.ts"
}
