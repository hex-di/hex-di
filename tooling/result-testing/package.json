{
  "name": "@hex-di/result-testing",
  "version": "0.2.1",
  "description": "Testing utilities for @hex-di/result - custom Vitest matchers and assertion helpers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./matchers": {
      "import": {
        "types": "./dist/matchers.d.ts",
        "default": "./dist/matchers.js"
      }
    },
    "./assertions": {
      "import": {
        "types": "./dist/assertion-helpers.d.ts",
        "default": "./dist/assertion-helpers.js"
      }
    },
    "./factories": {
      "import": {
        "types": "./dist/factories.d.ts",
        "default": "./dist/factories.js"
      }
    },
    "./gxp": {
      "import": {
        "types": "./dist/gxp.d.ts",
        "default": "./dist/gxp.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "test:cucumber": "cucumber-js",
    "test:mutate": "stryker run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "result",
    "testing",
    "vitest",
    "matchers",
    "assertions",
    "hex-di"
  ],
  "author": "Mohammad AL Mechkor <medalmechkor@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "tooling/result-testing"
  },
  "dependencies": {
    "@hex-di/result": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0"
  }
}
