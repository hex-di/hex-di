{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["*.config.{js,ts,mjs}", "*.mjs"],
      "project": ["*.{js,ts,mjs}"],
      "ignore": ["**/*.d.ts"]
    },
    "packages/*": {
      "entry": [
        "src/index.ts",
        "src/advanced.ts",
        "src/**/index.ts",
        "tests/**/*.test.{ts,tsx}",
        "tests/**/*.test-d.ts",
        "tests/**/*.bench.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignore": ["**/dist/**", "**/*.d.ts", "**/CONCEPT-*.ts", "**/.stryker-tmp/**"]
    },
    "integrations/*": {
      "entry": [
        "src/index.ts",
        "src/advanced.ts",
        "src/**/index.ts",
        "tests/**/*.test.{ts,tsx}",
        "tests/**/*.test-d.ts",
        "tests/**/*.bench.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignore": ["**/dist/**", "**/*.d.ts", "**/CONCEPT-*.ts", "**/.stryker-tmp/**"]
    },
    "libs/*/*": {
      "entry": [
        "src/index.ts",
        "src/advanced.ts",
        "src/**/index.ts",
        "tests/**/*.test.{ts,tsx}",
        "tests/**/*.test-d.ts",
        "tests/**/*.bench.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignore": ["**/dist/**", "**/*.d.ts", "**/CONCEPT-*.ts", "**/.stryker-tmp/**"]
    },
    "tooling/*": {
      "entry": [
        "src/index.ts",
        "src/advanced.ts",
        "src/**/index.ts",
        "tests/**/*.test.{ts,tsx}",
        "tests/**/*.test-d.ts",
        "tests/**/*.bench.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignore": ["**/dist/**", "**/*.d.ts", "**/CONCEPT-*.ts", "**/.stryker-tmp/**"]
    },
    "testing/*": {
      "entry": [
        "src/index.ts",
        "src/advanced.ts",
        "src/**/index.ts",
        "tests/**/*.test.{ts,tsx}",
        "tests/**/*.test-d.ts",
        "tests/**/*.bench.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"],
      "ignore": ["**/dist/**", "**/*.d.ts", "**/CONCEPT-*.ts", "**/.stryker-tmp/**"]
    },
    "examples/*": {
      "entry": ["src/index.{ts,tsx}", "src/main.{ts,tsx}", "src/server.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["**/dist/**", "**/*.d.ts"]
    },
    "examples/pokenerve/*": {
      "entry": ["src/index.{ts,tsx}", "src/main.{ts,tsx}", "src/server.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["**/dist/**", "**/*.d.ts"]
    },
    "presentations/*/app": {
      "entry": ["src/index.{ts,tsx}", "src/main.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["**/dist/**", "**/*.d.ts"]
    }
  },
  "ignoreWorkspaces": ["website"],
  "ignoreDependencies": ["@types/*"],
  "ignore": ["**/dist/**", "**/*.d.ts", "**/node_modules/**", "**/.stryker-tmp/**"]
}
