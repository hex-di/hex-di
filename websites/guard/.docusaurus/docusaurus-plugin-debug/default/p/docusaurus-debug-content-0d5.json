{"allContent":{"docusaurus-plugin-css-cascade-layers":{},"docusaurus-plugin-content-docs":{"default":{"loadedVersions":[{"versionName":"current","label":"Next","banner":null,"badge":false,"noIndex":false,"className":"docs-version-current","path":"/docs","tagsPath":"/docs/tags","editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs","isLast":true,"routePriority":-1,"sidebarFilePath":"/Users/u1070457/Projects/Perso/hex-di/websites/guard/sidebars.ts","contentPath":"/Users/u1070457/Projects/Perso/hex-di/websites/guard/docs","docs":[{"id":"advanced/architecture","title":"Architecture","description":"The guard package is organized into five layers, each with a distinct responsibility. Dependencies flow strictly downward -- enforcement depends on evaluation, evaluation depends on policy, and policy depends on tokens.","source":"@site/docs/advanced/architecture.md","sourceDirName":"advanced","slug":"/advanced/architecture","permalink":"/docs/advanced/architecture","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/advanced/architecture.md","tags":[],"version":"current","sidebarPosition":2,"frontMatter":{"sidebar_position":2,"title":"Architecture"},"sidebar":"docs","previous":{"title":"GxP Infrastructure","permalink":"/docs/advanced/gxp"}},{"id":"advanced/gxp","title":"GxP Infrastructure","description":"For regulated environments (pharmaceutical, biotech, medical devices), the guard package includes infrastructure that supports audit trail requirements, data integrity, and system lifecycle management.","source":"@site/docs/advanced/gxp.md","sourceDirName":"advanced","slug":"/advanced/gxp","permalink":"/docs/advanced/gxp","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/advanced/gxp.md","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1,"title":"GxP Infrastructure"},"sidebar":"docs","previous":{"title":"React Integration","permalink":"/docs/react"},"next":{"title":"Architecture","permalink":"/docs/advanced/architecture"}},{"id":"api/api-reference","title":"API Reference","description":"Complete reference for all exports from @hex-di/guard.","source":"@site/docs/api/api-reference.md","sourceDirName":"api","slug":"/api/api-reference","permalink":"/docs/api/api-reference","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/api/api-reference.md","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1,"title":"API Reference"},"sidebar":"docs","previous":{"title":"Serialization","permalink":"/docs/guides/serialization"},"next":{"title":"Testing","permalink":"/docs/testing"}},{"id":"concepts/evaluation","title":"Evaluation","description":"The evaluation layer is the pure core of the guard system. It takes a policy and a subject, walks the policy tree, and produces a Decision with a full trace.","source":"@site/docs/concepts/evaluation.md","sourceDirName":"concepts","slug":"/concepts/evaluation","permalink":"/docs/concepts/evaluation","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/concepts/evaluation.md","tags":[],"version":"current","sidebarPosition":4,"frontMatter":{"sidebar_position":4,"title":"Evaluation"},"sidebar":"docs","previous":{"title":"Policies & Composition","permalink":"/docs/concepts/policies"},"next":{"title":"Subjects","permalink":"/docs/concepts/subjects"}},{"id":"concepts/permissions","title":"Permissions","description":"Permissions are the atomic units of authorization. Each permission is a branded nominal token -- a value that carries its identity at both the type level and runtime.","source":"@site/docs/concepts/permissions.md","sourceDirName":"concepts","slug":"/concepts/permissions","permalink":"/docs/concepts/permissions","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/concepts/permissions.md","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1,"title":"Permissions"},"sidebar":"docs","previous":{"title":"Introduction","permalink":"/docs/"},"next":{"title":"Roles & Inheritance","permalink":"/docs/concepts/roles"}},{"id":"concepts/policies","title":"Policies & Composition","description":"Policies are serializable discriminated unions composed through algebraic combinators. Every policy is plain JSON data -- no callbacks, no closures, no hidden state.","source":"@site/docs/concepts/policies.md","sourceDirName":"concepts","slug":"/concepts/policies","permalink":"/docs/concepts/policies","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/concepts/policies.md","tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"sidebar_position":3,"title":"Policies & Composition"},"sidebar":"docs","previous":{"title":"Roles & Inheritance","permalink":"/docs/concepts/roles"},"next":{"title":"Evaluation","permalink":"/docs/concepts/evaluation"}},{"id":"concepts/roles","title":"Roles & Inheritance","description":"Roles aggregate permissions into named sets and support DAG-based inheritance with automatic permission flattening.","source":"@site/docs/concepts/roles.md","sourceDirName":"concepts","slug":"/concepts/roles","permalink":"/docs/concepts/roles","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/concepts/roles.md","tags":[],"version":"current","sidebarPosition":2,"frontMatter":{"sidebar_position":2,"title":"Roles & Inheritance"},"sidebar":"docs","previous":{"title":"Permissions","permalink":"/docs/concepts/permissions"},"next":{"title":"Policies & Composition","permalink":"/docs/concepts/policies"}},{"id":"concepts/subjects","title":"Subjects","description":"The AuthSubject is the identity being evaluated against a policy. It carries the subject's permissions, roles, and attributes.","source":"@site/docs/concepts/subjects.md","sourceDirName":"concepts","slug":"/concepts/subjects","permalink":"/docs/concepts/subjects","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/concepts/subjects.md","tags":[],"version":"current","sidebarPosition":5,"frontMatter":{"sidebar_position":5,"title":"Subjects"},"sidebar":"docs","previous":{"title":"Evaluation","permalink":"/docs/concepts/evaluation"},"next":{"title":"DI Integration","permalink":"/docs/guides/di-integration"}},{"id":"guides/di-integration","title":"DI Integration","description":"The enforcement layer bridges the pure evaluation core with HexDI's runtime container. enforcePolicy() wraps adapters so that policy evaluation runs automatically at resolution time.","source":"@site/docs/guides/di-integration.md","sourceDirName":"guides","slug":"/guides/di-integration","permalink":"/docs/guides/di-integration","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/guides/di-integration.md","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1,"title":"DI Integration"},"sidebar":"docs","previous":{"title":"Subjects","permalink":"/docs/concepts/subjects"},"next":{"title":"Port Gates","permalink":"/docs/guides/port-gates"}},{"id":"guides/port-gates","title":"Port Gates","description":"Port gate hooks provide infrastructure-level authorization at the container level. They operate before subject-aware guard enforcement and are designed for coarse-grained access control.","source":"@site/docs/guides/port-gates.md","sourceDirName":"guides","slug":"/guides/port-gates","permalink":"/docs/guides/port-gates","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/guides/port-gates.md","tags":[],"version":"current","sidebarPosition":2,"frontMatter":{"sidebar_position":2,"title":"Port Gates"},"sidebar":"docs","previous":{"title":"DI Integration","permalink":"/docs/guides/di-integration"},"next":{"title":"Serialization","permalink":"/docs/guides/serialization"}},{"id":"guides/serialization","title":"Serialization","description":"Policies in @hex-di/guard are data, not callbacks. This is a deliberate design choice that enables serialization, storage, transmission, and introspection.","source":"@site/docs/guides/serialization.md","sourceDirName":"guides","slug":"/guides/serialization","permalink":"/docs/guides/serialization","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/guides/serialization.md","tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"sidebar_position":3,"title":"Serialization"},"sidebar":"docs","previous":{"title":"Port Gates","permalink":"/docs/guides/port-gates"},"next":{"title":"API Reference","permalink":"/docs/api/api-reference"}},{"id":"index","title":"Introduction","description":"A policy-based authorization library for TypeScript applications, featuring composable policies, audit trails, and deep integration with dependency injection.","source":"@site/docs/index.md","sourceDirName":".","slug":"/","permalink":"/docs/","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/index.md","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1,"title":"Introduction"},"sidebar":"docs","next":{"title":"Permissions","permalink":"/docs/concepts/permissions"}},{"id":"react","title":"React Integration","description":"The @hex-di/guard-react package provides React components and hooks for integrating authorization into your UI, with full support for React Suspense.","source":"@site/docs/react.md","sourceDirName":".","slug":"/react","permalink":"/docs/react","draft":false,"unlisted":false,"editUrl":"https://github.com/leaderiop/hex-di/tree/main/docs/react.md","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1,"title":"React Integration"},"sidebar":"docs","previous":{"title":"Testing","permalink":"/docs/testing"},"next":{"title":"GxP Infrastructure","permalink":"/docs/advan