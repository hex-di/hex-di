{
  "name": "@hex-di/devtools-adapters",
  "version": "0.1.0",
  "description": "Adapter implementations for HexDI DevTools - includes decorators and concrete implementations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./decorators": {
      "import": {
        "types": "./dist/decorators/index.d.ts",
        "default": "./dist/decorators/index.js"
      }
    },
    "./graph-export": {
      "import": {
        "types": "./dist/graph-export/index.d.ts",
        "default": "./dist/graph-export/index.js"
      }
    },
    "./tracing": {
      "import": {
        "types": "./dist/tracing/index.d.ts",
        "default": "./dist/tracing/index.js"
      }
    },
    "./transport": {
      "import": {
        "types": "./dist/transport/index.d.ts",
        "default": "./dist/transport/index.js"
      }
    },
    "./observability": {
      "import": {
        "types": "./dist/observability/index.d.ts",
        "default": "./dist/observability/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "dependency-injection",
    "di",
    "hexagonal-architecture",
    "devtools",
    "adapters",
    "typescript",
    "type-safe"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "packages/devtools-adapters"
  },
  "dependencies": {
    "@hex-di/devtools-core": "workspace:*",
    "@hex-di/ports": "workspace:*",
    "@hex-di/graph": "workspace:*",
    "@hex-di/runtime": "workspace:*"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
