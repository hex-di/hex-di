{
  "name": "@hex-di/devtools-flow",
  "version": "0.0.1",
  "description": "Flow state machine visualization plugin for HexDI DevTools",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:types": "vitest run --typecheck",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@hex-di/devtools": "workspace:*",
    "@hex-di/flow": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@hex-di/devtools": "workspace:*",
    "@hex-di/flow": "workspace:*",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hex-di/hex-di.git",
    "directory": "packages/devtools-flow"
  },
  "keywords": [
    "hex-di",
    "devtools",
    "flow",
    "state-machine",
    "visualization",
    "plugin"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
