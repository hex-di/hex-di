{
  "name": "@hex-di/devtools-mcp",
  "version": "0.0.1",
  "description": "MCP server for HexDI DevTools - AI assistant integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hexdi-mcp": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:types": "vitest typecheck"
  },
  "keywords": [
    "hexdi",
    "devtools",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude"
  ],
  "author": "HexDI Team",
  "license": "MIT",
  "dependencies": {
    "@hex-di/devtools-core": "workspace:*",
    "@hex-di/devtools-network": "workspace:*",
    "@hex-di/devtools-ui": "workspace:*",
    "@hex-di/graph": "workspace:*",
    "@hex-di/runtime": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "zod": "^3.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
