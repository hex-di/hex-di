{
  "name": "@hex-di/devtools-react",
  "version": "0.0.1",
  "description": "React adapters for HexDI DevTools",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "import": "./dist/vite/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "test:types": "vitest typecheck --run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hex-di/devtools-core": "workspace:*",
    "@hex-di/devtools-network": "workspace:*",
    "@hex-di/devtools-ui": "workspace:*",
    "@hex-di/graph": "workspace:*",
    "@hex-di/ports": "workspace:*",
    "@hex-di/runtime": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-transition": "^3.0.8",
    "@types/d3-zoom": "^3.0.8",
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthropics/hex-di.git",
    "directory": "packages/devtools-react"
  },
  "keywords": [
    "hex-di",
    "devtools",
    "react",
    "dependency-injection"
  ],
  "license": "MIT"
}
