{
  "name": "@hex-di/logger-pino",
  "version": "0.1.0",
  "description": "Pino backend adapter for @hex-di/logger",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pino",
    "logging",
    "structured-logging",
    "hexagonal-architecture",
    "dependency-injection"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "packages/logger-pino"
  },
  "dependencies": {
    "pino": "^9.6.0"
  },
  "peerDependencies": {
    "@hex-di/core": "workspace:*",
    "@hex-di/logger": "workspace:*"
  },
  "devDependencies": {
    "@hex-di/logger": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
