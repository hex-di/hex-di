{
  "name": "@hex-di/devtools-network",
  "version": "0.1.0",
  "description": "Network layer for HexDI DevTools - WebSocket server and client communication",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hexdi-devtools": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./middleware/express": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.js"
    },
    "./middleware/fastify": {
      "types": "./dist/middleware/fastify.d.ts",
      "import": "./dist/middleware/fastify.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hex-di/devtools-core": "workspace:*",
    "@hex-di/graph": "workspace:*",
    "@hex-di/ports": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@hex-di/devtools-testing": "workspace:*",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "fastify": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hex-di/hex-di.git",
    "directory": "packages/devtools-network"
  },
  "keywords": [
    "hex-di",
    "devtools",
    "websocket",
    "server",
    "client",
    "network"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
