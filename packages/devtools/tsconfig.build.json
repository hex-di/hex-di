{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["ES2021", "DOM"],
    "jsx": "react-jsx",
    "paths": {
      "#shared/*": ["./src/shared/*"],
      "#dom/*": ["./src/dom/*"],
      "#tui/*": ["./src/tui/*"],
      "#state/*": ["./src/state/*"],
      "#components/*": ["./src/components/*"],
      "#hooks/*": ["./src/hooks/*"],
      "#ports/*": ["./src/ports/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
