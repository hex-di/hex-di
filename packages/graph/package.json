{
  "name": "@hex-di/graph",
  "version": "0.1.0",
  "description": "Dependency graph construction and compile-time validation layer for HexDI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./advanced": {
      "import": {
        "types": "./dist/advanced.d.ts",
        "default": "./dist/advanced.js"
      },
      "require": {
        "types": "./dist/advanced.d.cts",
        "default": "./dist/advanced.cjs"
      }
    },
    "./inspection": {
      "import": {
        "types": "./dist/inspection.d.ts",
        "default": "./dist/inspection.js"
      },
      "require": {
        "types": "./dist/inspection.d.cts",
        "default": "./dist/inspection.cjs"
      }
    },
    "./internal": {
      "import": {
        "types": "./dist/internal.d.ts",
        "default": "./dist/internal.js"
      },
      "require": {
        "types": "./dist/internal.d.cts",
        "default": "./dist/internal.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:types": "vitest run --typecheck",
    "test:coverage": "vitest run --coverage",
    "test:bench": "vitest bench",
    "test:mutation": "stryker run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "dependency-injection",
    "di",
    "hexagonal-architecture",
    "graph",
    "typescript",
    "type-safe",
    "compile-time-validation"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hex-di/hex-di.git",
    "directory": "packages/graph"
  },
  "bugs": {
    "url": "https://github.com/hex-di/hex-di/issues"
  },
  "homepage": "https://github.com/hex-di/hex-di/tree/main/packages/graph#readme",
  "dependencies": {
    "@hex-di/core": "workspace:*",
    "@hex-di/result": "workspace:*"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "@hex-di/result-testing": "workspace:*",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@vitest/coverage-v8": "4.0.18",
    "fast-check": "^4.5.3"
  }
}
